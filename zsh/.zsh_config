alias vim="nvim"
alias wi="cd ~/wiki && nvim -c ':VimwikiIndex'"
alias wd="cd ~/wiki && nvim -c ':VimwikiDiaryIndex'"

export LANG=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8
export ZSH_THEME="robbyrussell"

[ -d "$(brew --prefix mpich 2>/dev/null)" ] && export PATH="$(brew --prefix mpich)/bin:$PATH"
[ -d "$HOME/google-cloud-sdk/bin" ] && export PATH="$HOME/google-cloud-sdk/bin:$PATH"

if [ -d ~/spack ]; then
  . ~/spack/share/spack/setup-env.sh
  spack env activate dev-env 2>/dev/null || true
fi

command -v fzf &>/dev/null && source <(fzf --zsh)
